# Dependencies
node_modules/
**/node_modules/
.pnpm-store/

# Lockfiles (pnpm workspace keeps pnpm-lock.yaml)
package-lock.json
**/package-lock.json

# Build artifacts
dist/
**/dist/
core/dist-*/
core/dist-nest/
web/stats.html
*.tsbuildinfo

# Runtime data
data/
core/data/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env & local
.env
.env.*
!.env.example
*.local

# Editor & OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Panel build artifacts (generated by pnpm build:web)
core/panel/assets/
core/panel/*.bak*
core/panel/js/*.bak*

# Backup files
**/*.bak_*
*.bak

# Sensitive / personal files
network_b64.txt
start-*.ps1

# Runtime / temp
/tmp/
